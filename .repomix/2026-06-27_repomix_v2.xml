<file path=".github/workflows/ci.yml">
name: CI

on:
  pull_request:
    branches: ["main"]

# Annule les runs précédents pour la même PR (économie de minutes CI)
concurrency:
  group: ci-${{ github.ref }}
  cancel-in-progress: true

jobs:
  lint:
    name: Lint
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-python@v5
        with:
          python-version: "3.12"
      - uses: astral-sh/setup-uv@v3
        with:
          enable-cache: true
      - run: uv sync
      - run: uv run ruff check src/
      - run: uv run ruff format --check src/
      - run: uv run python -m mypy src/

  test:
    name: Tests (Python ${{ matrix.python-version }})
    runs-on: ubuntu-latest
    needs: lint  # les tests ne tournent que si lint passe

    strategy:
      matrix:
        python-version: ["3.12", "3.13"]

    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-python@v5
        with:
          python-version: ${{ matrix.python-version }}
      - uses: astral-sh/setup-uv@v3
        with:
          enable-cache: true
      - run: uv sync
      - run: |
          uv run python -m pytest \
            --cov=src/okflint \
            --cov-report=term-missing \
            --cov-fail-under=85

  commitizen:
    name: Commitizen (format des commits)
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
        with:
          fetch-depth: 0  # fetch tout l'historique pour valider les messages
      - uses: actions/setup-python@v5
        with:
          python-version: "3.12"
      - uses: astral-sh/setup-uv@v3
        with:
          enable-cache: true
      - run: uv sync
      - name: Validate commit messages
        run: uv run cz check --rev-range origin/main..HEAD
</file>

<file path=".github/workflows/release.yml">
name: Release

on:
  push:
    tags:
      - "v*.*.*"  # déclenché sur les tags de version : v0.1.0, v0.2.0, etc.

jobs:
  # ── Étape 1 : lint + tests (sécurité avant publication) ──────────────────
  validate:
    name: Lint + Tests
    runs-on: ubuntu-latest

    steps:
      - uses: actions/checkout@v4

      - name: Set up Python 3.12
        uses: actions/setup-python@v5
        with:
          python-version: "3.12"

      - name: Install uv
        uses: astral-sh/setup-uv@v3
        with:
          enable-cache: true

      - name: Install dependencies
        run: uv sync

      - name: Lint
        run: |
          uv run ruff check src/
          uv run ruff format --check src/
          uv run python -m mypy src/

      - name: Tests
        run: uv run python -m pytest --cov=src/okflint --cov-fail-under=85

  # ── Étape 2 : build + publication PyPI ────────────────────────────────────
  publish:
    name: Build + Publish PyPI
    runs-on: ubuntu-latest
    needs: validate  # n'exécute que si validate est vert

    environment:
      name: pypi
      url: https://pypi.org/project/okflint/

    permissions:
      id-token: write  # nécessaire pour la publication via Trusted Publisher PyPI

    steps:
      - uses: actions/checkout@v4

      - name: Set up Python 3.12
        uses: actions/setup-python@v5
        with:
          python-version: "3.12"

      - name: Install uv
        uses: astral-sh/setup-uv@v3
        with:
          enable-cache: true

      - name: Install dependencies
        run: uv sync

      - name: Build sdist + wheel
        run: uv build

      - name: Publish to PyPI
        uses: pypa/gh-action-pypi-publish@release/v1
        # Authentification via Trusted Publisher (pas de token à stocker)
        # Configuration à faire une fois sur pypi.org → Manage → Publishing

  # ── Étape 3 : GitHub Release avec notes auto-générées ────────────────────
  github-release:
    name: GitHub Release
    runs-on: ubuntu-latest
    needs: publish

    permissions:
      contents: write

    steps:
      - uses: actions/checkout@v4
        with:
          fetch-depth: 0  # fetch tout l'historique pour les notes de release

      - name: Create GitHub Release
        uses: softprops/action-gh-release@v2
        with:
          generate_release_notes: true  # génère les notes depuis les commits
          files: dist/*
</file>

