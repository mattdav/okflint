        parser = build_parser()
        args = parser.parse_args(
            ["audit", "--bundle", str(bundle), "--vault", str(bundle)]
        )
        assert _cmd_audit(args) == 0

    def test_audit_with_apply_writes_json(
        self,
        tmp_path: Path,
        make_md: Callable[[Path, str], Path],
