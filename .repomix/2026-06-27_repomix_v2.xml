jobs:
  build-and-deploy:
    name: Build Sphinx + Deploy GitHub Pages
    runs-on: ubuntu-latest

    permissions:
      contents: write  # nécessaire pour pousser sur gh-pages

    steps:
      - uses: actions/checkout@v4
        with:
          persist-credentials: false

      - name: Set up Python 3.12
