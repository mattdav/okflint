# ============================================================
# Variables d'environnement — okf_converter
# ============================================================
# Copier ce fichier en .env et renseigner les valeurs réelles.
# Ne jamais commiter .env (il est dans .gitignore).
# ============================================================

# -- Environnement applicatif --------------------------------
# Valeurs possibles : development, staging, production
APP_ENV=development

# -- Exemple : API externe -----------------------------------
# URL de base de l'API (obligatoire)
# API_BASE_URL=https://api.example.com

# Clé d'API (obligatoire en production)
# API_KEY=

# Timeout des requêtes en secondes (défaut : 30)
# REQUEST_TIMEOUT=30

# -- Exemple : Base de données -------------------------------
# DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# -- Logging -------------------------------------------------
# Niveau de log : DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
